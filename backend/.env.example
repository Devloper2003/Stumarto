# Server Configuration
PORT=5000

# MongoDB Configuration
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/school-marketplace

# MongoDB Atlas (Cloud):
# Note: Password must be URL-encoded. Special characters:
# < = %3C, @ = %40, > = %3E, # = %23, % = %25, / = %2F, : = %3A
# Example: If password is `Stumarto@321`, it becomes `Stumarto%40321`
MONGODB_URI=mongodb+srv://root:root123@stumarto.zinhy1d.mongodb.net/?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=stumarto-secret
JWT_EXPIRES_IN=7d

# Razorpay Configuration (Test Mode)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Payments Mode
# - mock: works without Razorpay account/keys (dev/testing)
# - razorpay: real Razorpay test/live keys (signature verification enabled)
# If keys are missing, backend automatically falls back to mock mode.
PAYMENT_MODE=mock

# Add other environment variables here as needed
